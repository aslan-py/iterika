# ── Wildberries ─────────────────────────────────────────────
# Поисковый запрос (категория товаров)
WB_QUERY=смартфоны
# Сколько товаров собирать (для полного прогона)
WB_MAX_PRODUCTS=10000
# Случайная задержка между запросами: пауза = random(MIN, MAX) секунд
WB_DELAY_MIN=1.0
WB_DELAY_MAX=3.0

# Перцентили сегментов: Эконом < p_economy < Стандарт < p_premium < Премиум
# 0.30 / 0.95 → Эконом=30%, Стандарт=50%, Премиум=5%
SEGMENT_P_ECONOMY=0.30
SEGMENT_P_PREMIUM=0.95

# ── DeepSeek LLM ─────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_MODEL=deepseek-chat
# Сколько товаров в одном батч-запросе к LLM
LLM_BATCH_SIZE=30

# ── Redis ────────────────────────────────────────────────────
# Локальная разработка: redis://localhost:6379/0
# Внутри docker-compose: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
# TTL кэша сегментов в секундах (30 дней = 2592000)
REDIS_CACHE_TTL=2592000

# ── AmoCRM ───────────────────────────────────────────────────
# Поддомен вашего аккаунта (например: mycompany → mycompany.amocrm.ru)
AMOCRM_SUBDOMAIN=yourcompany
# Долгоживущий токен интеграции из настроек AmoCRM
AMOCRM_ACCESS_TOKEN=your_token_here

# ── Режим работы ─────────────────────────────────────────────
# true = собирать только DEMO_LIMIT товаров (для локального тестирования)
DEMO_MODE=True
DEMO_LIMIT=200
OUTPUT_DIR=output
