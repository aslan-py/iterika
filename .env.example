# ── Wildberries ─────────────────────────────────────────────
# Поисковый запрос (категория товаров)
WB_QUERY=смартфон
# Сколько товаров собирать (для полного прогона)
WB_MAX_PRODUCTS=10000
# Случайная задержка между запросами: пауза = random(MIN, MAX) секунд
WB_DELAY_MIN=1.0
WB_DELAY_MAX=3.0

# ── DeepSeek LLM ─────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_MODEL=deepseek-chat
# Сколько товаров в одном батч-запросе к LLM
LLM_BATCH_SIZE=30

# ── AmoCRM ───────────────────────────────────────────────────
# Поддомен вашего аккаунта (например: mycompany → mycompany.amocrm.ru)
AMOCRM_SUBDOMAIN=yourcompany
# Долгоживущий токен интеграции из настроек AmoCRM
AMOCRM_ACCESS_TOKEN=your_token_here

# ── Режим работы ─────────────────────────────────────────────
# true = собирать только DEMO_LIMIT товаров (для локального тестирования)
DEMO_MODE=True
DEMO_LIMIT=5
OUTPUT_DIR=output
